---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import TableOfContents from '../components/TableOfContents.astro';
import SidebarOfContents from '../components/SidebarOfContents.astro';
import Twikoo from '../components/Twikoo.astro';
import WelcomeAnimation from '../components/WelcomeAnimation.astro';
import ArticleMetaCard from '../components/ArticleMetaCard.astro';
import RecentPosts from '../components/RecentPosts.astro';
import { calculateReadingTime, calculateWordCount } from '../utils/readingTime';
const defaultCover = '/img/df-cover.webp';
import { ClientRouter } from 'astro:transitions';
import "@fancyapps/ui/dist/fancybox/fancybox.css";

type Props = Partial<CollectionEntry<'post'>['data']> & {
  title: string;
  description: string;
  pubDate: Date;
  heroImageWidth?: string;
  showDate?: boolean;
  showComments?: boolean;
  isEncrypted?: boolean;
  id?: string;
  tags?: string[];
  category?: string;
};

const { title, description, pubDate, updatedDate, heroImage, heroImageWidth, showDate = true, showComments = true, id, tags, category } = Astro.props;
const displayImage = heroImage || defaultCover;

const content = Astro.slots.has('default') ? await Astro.slots.render('default') : '';
const wordCount = calculateWordCount(content);
const readingTime = calculateReadingTime(content);
---

<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} image={displayImage} pubDate={pubDate} updatedDate={updatedDate} article={true} />
		<ClientRouter />
		<script is:inline>
			(function() {
				const theme = localStorage.getItem('theme') ||
					(window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
				document.documentElement.classList.toggle('dark', theme === 'dark');
			})();
		</script>
		<script is:inline>
			(function() {
				if (!sessionStorage.getItem('hasVisited')) {
					const style = document.createElement('style');
					style.textContent = '#main-content{opacity:0;}';
					document.head.appendChild(style);
				}
			})();
		</script>
	</head>

	<body class="min-h-screen flex flex-col bg-background-light text-text-light dark:bg-background-dark dark:text-text-dark">
		<div class="bg-glow" aria-hidden="true">
			<div class="bg-glow__orb bg-glow__orb--1"></div>
			<div class="bg-glow__orb bg-glow__orb--2"></div>
			<div class="bg-glow__orb bg-glow__orb--3"></div>
		</div>
		<WelcomeAnimation />
		<div id="main-content" class="flex flex-col min-h-screen transition-opacity duration-300">
			<Header />
			<TableOfContents />
			<SidebarOfContents />
			<main class="flex-1 pt-2 page-transition">
			<div class="max-w-[1340px] mx-auto">
				<!-- 大屏幕布局 -->
				<div class="hidden xl:grid grid-cols-[272px_1fr_272px] gap-8">
					<div></div>
					<article id="article-content-desktop" class="article-content max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
						<div class={heroImageWidth ? "mt-12 mb-6 mx-auto overflow-hidden rounded-full shadow-lg bg-hero-light dark:bg-hero-dark transition-transform duration-300 ease-[cubic-bezier(0.25,0.46,0.45,0.94)] hover:scale-110 cursor-pointer" : "mb-6 overflow-hidden rounded-3xl shadow-lg bg-hero-light dark:bg-hero-dark transition-transform duration-300 ease-[cubic-bezier(0.25,0.46,0.45,0.94)] hover:scale-105 cursor-pointer"} style={heroImageWidth ? `width: ${heroImageWidth}px; aspect-ratio: 1/1;` : 'aspect-ratio: 2/1;'}>
							<div
								class="w-full h-full bg-cover bg-center"
								style={`background-image: url('${displayImage}');`}
								aria-label="文章封面"
							></div>
						</div>
						<div class="text-center -mb-4">
							<h1 data-article-title class="text-4xl font-bold text-text-light dark:text-text-dark mb-4">{title}</h1>
							{showDate && (
								<div class="flex flex-wrap items-center justify-center gap-3 mb-4">
									<div class="group relative flex items-center gap-2 px-4 py-2 rounded-full bg-white/50 dark:bg-badge-dark/60 text-sm text-text-light dark:text-text-dark">
										<div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-3 whitespace-nowrap px-3 py-2 bg-card-light dark:bg-card-dark tooltip-solid text-text-light dark:text-text-dark text-sm rounded-xl shadow-2xl opacity-0 invisible scale-95 [@media(hover:hover)]:group-hover:opacity-100 [@media(hover:hover)]:group-hover:visible [@media(hover:hover)]:group-hover:scale-100 transition-all duration-300 pointer-events-none z-10 origin-bottom">
											文章字数统计
										</div>
										<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
										</svg>
										<span>{(wordCount / 1000).toFixed(1)}K 字</span>
									</div>
									<div class="group relative flex items-center gap-2 px-4 py-2 rounded-full bg-white/50 dark:bg-badge-dark/60 text-sm text-text-light dark:text-text-dark">
										<div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-3 whitespace-nowrap px-3 py-2 bg-card-light dark:bg-card-dark tooltip-solid text-text-light dark:text-text-dark text-sm rounded-xl shadow-2xl opacity-0 invisible scale-95 [@media(hover:hover)]:group-hover:opacity-100 [@media(hover:hover)]:group-hover:visible [@media(hover:hover)]:group-hover:scale-100 transition-all duration-300 pointer-events-none z-10 origin-bottom">
											预计阅读时间
										</div>
										<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
										</svg>
										<span>{readingTime} 分钟</span>
									</div>
									<div class="group relative flex items-center gap-2 px-4 py-2 rounded-full bg-white/50 dark:bg-badge-dark/60 text-sm text-text-light dark:text-text-dark">
										<div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-3 whitespace-nowrap px-3 py-2 bg-card-light dark:bg-card-dark tooltip-solid text-text-light dark:text-text-dark text-sm rounded-xl shadow-2xl opacity-0 invisible scale-95 [@media(hover:hover)]:group-hover:opacity-100 [@media(hover:hover)]:group-hover:visible [@media(hover:hover)]:group-hover:scale-100 transition-all duration-300 pointer-events-none z-10 origin-bottom">
											文章发布日期
										</div>
										<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
										</svg>
										<span><FormattedDate date={pubDate} /></span>
									</div>
									{updatedDate && (
										<div class="group relative flex items-center gap-2 px-4 py-2 rounded-full bg-white/50 dark:bg-badge-dark/60 text-sm text-text-light dark:text-text-dark">
											<div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-3 whitespace-nowrap px-3 py-2 bg-card-light dark:bg-card-dark tooltip-solid text-text-light dark:text-text-dark text-sm rounded-xl shadow-2xl opacity-0 invisible scale-95 [@media(hover:hover)]:group-hover:opacity-100 [@media(hover:hover)]:group-hover:visible [@media(hover:hover)]:group-hover:scale-100 transition-all duration-300 pointer-events-none z-10 origin-bottom">
												文章更新日期
											</div>
											<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
											</svg>
											<span><FormattedDate date={updatedDate} /></span>
										</div>
									)}
									{category && (
										<a 
											href={`/categories/${category}`}
											class="group relative flex items-center gap-2 px-4 py-2 rounded-full bg-white/50 dark:bg-badge-dark/60 text-sm text-text-light dark:text-text-dark hover:bg-white dark:hover:bg-badge-dark/90 transition-colors"
										>
											<div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-3 whitespace-nowrap px-3 py-2 bg-card-light dark:bg-card-dark tooltip-solid text-text-light dark:text-text-dark text-sm rounded-xl shadow-2xl opacity-0 invisible scale-95 [@media(hover:hover)]:group-hover:opacity-100 [@media(hover:hover)]:group-hover:visible [@media(hover:hover)]:group-hover:scale-100 transition-all duration-300 pointer-events-none z-10 origin-bottom">
												查看 {category} 分类下的所有文章
											</div>
											<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
												<path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
											</svg>
											<span>{category}</span>
										</a>
									)}
								</div>
							)}
						</div>
						<div class="prose prose-lg max-w-none text-text-light dark:prose-invert dark:text-text-dark prose-headings:font-bold prose-a:text-primary-light dark:prose-a:text-primary-dark prose-blockquote:border-l-primary-light dark:prose-blockquote:border-l-primary-dark">
							<slot />
						</div>
						{showComments && (
							<>
								<div class="my-4 flex items-center justify-between">
									<div class="flex items-center gap-2 flex-1">
										{tags && tags.length > 0 && (
											<div class="flex items-center gap-2 flex-wrap ml-2">
												{tags.map((tag) => (
													<a 
														href={`/tags/${tag}`}
														class="group relative px-2 py-1 text-xs font-medium bg-gray-100/80 dark:bg-white/10 text-gray-500 dark:text-gray-400 rounded-full hover:bg-gray-200/80 dark:hover:bg-white/20 transition-colors"
													>
														<div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-3 whitespace-nowrap px-3 py-2 bg-card-light dark:bg-card-dark tooltip-solid text-text-light dark:text-text-dark text-sm rounded-xl shadow-2xl opacity-0 invisible scale-95 [@media(hover:hover)]:group-hover:opacity-100 [@media(hover:hover)]:group-hover:visible [@media(hover:hover)]:group-hover:scale-100 transition-all duration-300 pointer-events-none z-10 origin-bottom">
															查看 {tag} 标签下的所有文章
														</div>
														# {tag}
													</a>
												))}
											</div>
										)}
									</div>
									<div class="flex items-center gap-2 px-3 py-1.5 rounded-full bg-gray-100/80 dark:bg-white/10 flex-shrink-0 mr-2">
										<svg class="w-4 h-4 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
										</svg>
										<span class="text-xs font-medium text-gray-400 dark:text-gray-500 whitespace-nowrap">文章结束</span>
									</div>
								</div>
								
								<ArticleMetaCard 
									title={title} 
									url={Astro.url?.href || ''} 
									pubDate={pubDate} 
									updatedDate={updatedDate} 
								/>
								
								<RecentPosts currentPostId={id || ''} />
								{/* 评论区分隔区域 */}
								<div id="comments-section" class="mt-16 mb-8 flex flex-col items-center gap-4">
									<div class="flex items-center gap-3">
										<div class="h-px w-12 sm:w-32 bg-gradient-to-r from-transparent to-text-light/20 dark:to-text-dark/40"></div>
										<div class="flex items-center gap-2 px-4 py-2 rounded-full bg-white/40 dark:bg-badge-dark/60 flex-shrink-0">
											<svg class="w-5 h-5 text-primary-light dark:text-primary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
											</svg>
											<span class="text-sm font-medium text-text-light dark:text-text-dark whitespace-nowrap">评论区</span>
										</div>
										<div class="h-px w-12 sm:w-32 bg-gradient-to-l from-transparent to-text-light/20 dark:to-text-dark/40"></div>
									</div>
								</div>
								<Twikoo />
							</>
						)}
					</article>
					<div></div>
				</div>
				<!-- 中等屏幕和小屏幕布局 -->
				<div class="xl:hidden">
					<article id="article-content-mobile" class="article-content max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
						<div class={heroImageWidth ? "mt-12 mb-6 mx-auto overflow-hidden rounded-full shadow-lg bg-hero-light dark:bg-hero-dark transition-transform duration-300 ease-[cubic-bezier(0.25,0.46,0.45,0.94)] hover:scale-110 cursor-pointer" : "mb-6 overflow-hidden rounded-3xl shadow-lg bg-hero-light dark:bg-hero-dark transition-transform duration-300 ease-[cubic-bezier(0.25,0.46,0.45,0.94)] hover:scale-105 cursor-pointer"} style={heroImageWidth ? `width: ${heroImageWidth}px; aspect-ratio: 1/1;` : 'aspect-ratio: 2/1;'}>
							<div
								class="w-full h-full bg-cover bg-center"
								style={`background-image: url('${displayImage}');`}
								aria-label="文章封面"
							></div>
						</div>
						<div class="text-center -mb-4">
							<h1 data-article-title class="text-4xl font-bold text-text-light dark:text-text-dark mb-4">{title}</h1>
							{showDate && (
								<div class="flex flex-wrap items-center justify-center gap-3 mb-4">
									<div class="group relative flex items-center gap-2 px-4 py-2 rounded-full bg-badge-light dark:bg-badge-dark/60 text-sm text-text-light dark:text-text-dark">
										<div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-3 whitespace-nowrap px-3 py-2 bg-card-light dark:bg-card-dark tooltip-solid text-text-light dark:text-text-dark text-sm rounded-xl shadow-2xl opacity-0 invisible scale-95 [@media(hover:hover)]:group-hover:opacity-100 [@media(hover:hover)]:group-hover:visible [@media(hover:hover)]:group-hover:scale-100 transition-all duration-300 pointer-events-none z-10 origin-bottom">
											文章字数统计
										</div>
										<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
										</svg>
										<span>{(wordCount / 1000).toFixed(1)}K 字</span>
									</div>
									<div class="group relative flex items-center gap-2 px-4 py-2 rounded-full bg-badge-light dark:bg-badge-dark/60 text-sm text-text-light dark:text-text-dark">
										<div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-3 whitespace-nowrap px-3 py-2 bg-card-light dark:bg-card-dark tooltip-solid text-text-light dark:text-text-dark text-sm rounded-xl shadow-2xl opacity-0 invisible scale-95 [@media(hover:hover)]:group-hover:opacity-100 [@media(hover:hover)]:group-hover:visible [@media(hover:hover)]:group-hover:scale-100 transition-all duration-300 pointer-events-none z-10 origin-bottom">
											预计阅读时间
										</div>
										<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
										</svg>
										<span>{readingTime} 分钟</span>
									</div>
									<div class="group relative flex items-center gap-2 px-4 py-2 rounded-full bg-badge-light dark:bg-badge-dark/60 text-sm text-text-light dark:text-text-dark">
										<div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-3 whitespace-nowrap px-3 py-2 bg-card-light dark:bg-card-dark tooltip-solid text-text-light dark:text-text-dark text-sm rounded-xl shadow-2xl opacity-0 invisible scale-95 [@media(hover:hover)]:group-hover:opacity-100 [@media(hover:hover)]:group-hover:visible [@media(hover:hover)]:group-hover:scale-100 transition-all duration-300 pointer-events-none z-10 origin-bottom">
											文章发布日期
										</div>
										<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
										</svg>
										<span>发布于 <FormattedDate date={pubDate} /></span>
									</div>
									{updatedDate && (
										<div class="group relative flex items-center gap-2 px-4 py-2 rounded-full bg-badge-light dark:bg-badge-dark/60 text-sm text-text-light dark:text-text-dark">
											<div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-3 whitespace-nowrap px-3 py-2 bg-card-light dark:bg-card-dark tooltip-solid text-text-light dark:text-text-dark text-sm rounded-xl shadow-2xl opacity-0 invisible scale-95 [@media(hover:hover)]:group-hover:opacity-100 [@media(hover:hover)]:group-hover:visible [@media(hover:hover)]:group-hover:scale-100 transition-all duration-300 pointer-events-none z-10 origin-bottom">
												文章更新日期
											</div>
											<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
											</svg>
											<span>更新于 <FormattedDate date={updatedDate} /></span>
										</div>
									)}
									{category && (
										<a 
											href={`/categories/${category}`}
											class="group relative flex items-center gap-2 px-4 py-2 rounded-full bg-badge-light dark:bg-badge-dark/60 text-sm text-text-light dark:text-text-dark hover:bg-gray-200/80 dark:hover:bg-gray-700/80 transition-colors"
										>
											<div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-3 whitespace-nowrap px-3 py-2 bg-card-light dark:bg-card-dark tooltip-solid text-text-light dark:text-text-dark text-sm rounded-xl shadow-2xl opacity-0 invisible scale-95 [@media(hover:hover)]:group-hover:opacity-100 [@media(hover:hover)]:group-hover:visible [@media(hover:hover)]:group-hover:scale-100 transition-all duration-300 pointer-events-none z-10 origin-bottom">
												查看分类 {category} 下的所有文章
											</div>
											<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
												<path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
											</svg>
											<span>{category}</span>
										</a>
									)}
								</div>
							)}
						</div>
						<div class="prose prose-lg max-w-none text-text-light dark:prose-invert dark:text-text-dark prose-headings:font-bold prose-a:text-primary-light dark:prose-a:text-primary-dark prose-blockquote:border-l-primary-light dark:prose-blockquote:border-l-primary-dark">
							<slot />
						</div>
						{showComments && (
							<>
								<div class="my-4 flex items-center justify-between">
									<div class="flex items-center gap-2 flex-1">
										{tags && tags.length > 0 && (
											<div class="flex items-center gap-2 flex-wrap ml-2">
												{tags.map((tag) => (
													<a 
														href={`/tags/${tag}`}
														class="group relative px-2 py-1 text-xs font-medium bg-gray-100/80 dark:bg-white/80 text-gray-500 dark:text-gray-400 rounded-full hover:bg-gray-200/80 dark:hover:bg-gray-700/80 transition-colors"
													>
														<div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-3 whitespace-nowrap px-3 py-2 bg-card-light dark:bg-card-dark tooltip-solid text-text-light dark:text-text-dark text-sm rounded-xl shadow-2xl opacity-0 invisible scale-95 [@media(hover:hover)]:group-hover:opacity-100 [@media(hover:hover)]:group-hover:visible [@media(hover:hover)]:group-hover:scale-100 transition-all duration-300 pointer-events-none z-10 origin-bottom">
															查看标签 {tag} 下的所有文章
														</div>
														# {tag}
													</a>
												))}
											</div>
										)}
									</div>
									<div class="flex items-center gap-2 px-3 py-1.5 rounded-full bg-gray-100/80 dark:bg-gray-800/80 flex-shrink-0 mr-2">
										<svg class="w-4 h-4 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
										</svg>
										<span class="text-xs font-medium text-gray-400 dark:text-gray-500 whitespace-nowrap">文章结束</span>
									</div>
								</div>
								
								<ArticleMetaCard 
									title={title} 
									url={Astro.url?.href || ''} 
									pubDate={pubDate} 
									updatedDate={updatedDate} 
								/>
								
								<RecentPosts currentPostId={id || ''} />
								{/* 评论区分隔区域 */}
								<div id="comments-section" class="mt-16 mb-8 flex flex-col items-center gap-4">
									<div class="flex items-center gap-3">
										<div class="h-px w-12 sm:w-32 bg-gradient-to-r from-transparent to-text-light/20 dark:to-text-dark/40"></div>
										<div class="flex items-center gap-2 px-4 py-2 rounded-full bg-badge-light dark:bg-badge-dark/60 flex-shrink-0">
											<svg class="w-5 h-5 text-primary-light dark:text-primary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
											</svg>
											<span class="text-sm font-medium text-text-light dark:text-text-dark whitespace-nowrap">评论区</span>
										</div>
										<div class="h-px w-12 sm:w-32 bg-gradient-to-l from-transparent to-text-light/20 dark:to-text-dark/40"></div>
									</div>
								</div>
								<Twikoo />
							</>
						)}
					</article>
				</div>
			</div>
		</main>
		<Footer />
	</div>
		<script is:inline>
			function getGreeting() {
				var hour = new Date().getHours();
				
				if (hour >= 5 && hour < 12) {
					return '早上好，夜之城！';
				} else if (hour >= 12 && hour < 14) {
					return '真香！';
				} else if (hour >= 14 && hour < 18) {
					return '三点几哩，饮茶先啦！';
				} else if (hour >= 18 && hour < 22) {
					return '打工是不可能打工的！';
				} else {
					return '你见过凌晨四点的洛杉矶吗？';
				}
			}

			function runWelcomeAnimation() {
				var hasVisited = sessionStorage.getItem('hasVisited');

				if (hasVisited) {
					return;
				}

				sessionStorage.setItem('hasVisited', 'true');

				var mainContent = document.getElementById('main-content');
				var overlay = document.getElementById('welcome-overlay');
				var avatar = document.getElementById('welcome-avatar');
				var logo = document.getElementById('welcome-logo');
				var tagline = document.getElementById('welcome-tagline');
				var greeting = document.getElementById('welcome-greeting');
				var greetingInner = document.getElementById('welcome-greeting-inner');

				if (!overlay || !avatar || !logo || !tagline || !greeting || !greetingInner) return;

				greetingInner.textContent = getGreeting();

				if (mainContent) {
					mainContent.style.opacity = '0';
				}

				overlay.classList.add('active');

				setTimeout(function() {
					avatar.classList.add('animate');
				}, 100);

				setTimeout(function() {
					logo.classList.add('animate');
				}, 300);

				setTimeout(function() {
					tagline.classList.add('animate');
				}, 500);

				setTimeout(function() {
					greeting.classList.add('animate');
				}, 700);

				setTimeout(function() {
					overlay.classList.add('fade-out');

					if (mainContent) {
						mainContent.style.opacity = '1';
					}

					setTimeout(function() {
						overlay.classList.remove('active');
						overlay.style.display = 'none';
					}, 500);
				}, 2500);
			}

			if (document.readyState === 'loading') {
				document.addEventListener('DOMContentLoaded', runWelcomeAnimation);
			} else {
				runWelcomeAnimation();
			}
		</script>
		<script>
			import { Fancybox } from "@fancyapps/ui";

			function bindFancybox() {
				Fancybox.unbind("[data-fancybox]");
				Fancybox.close();

				Fancybox.bind("[data-fancybox]", {
					Hash: false,
					hideScrollbar: false,
				});
			}

			document.addEventListener('astro:page-load', () => {
				const preElements = document.querySelectorAll('.prose pre');
				preElements.forEach((pre) => {
					const code = pre.querySelector('code');
					if (!code) return;
					
					const langAttr = pre.getAttribute('data-language') || code.getAttribute('data-language');
					const lang = langAttr ? langAttr.charAt(0).toUpperCase() + langAttr.slice(1) : 'Code';
					
					const header = document.createElement('div');
					header.className = 'code-header';
					header.innerHTML = `
						<div class="code-title">
							<svg class="toggle-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
							</svg>
							<span>${lang}</span>
						</div>
						<button class="copy-btn" title="Copy">
							<svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
							</svg>
						</button>
					`;
					
					pre.insertBefore(header, code);
					pre.classList.add('collapsed');
					
					header.addEventListener('click', (e) => {
						const target = e.target as HTMLElement;
						if (target.closest('.copy-btn')) {
							e.stopPropagation();
							navigator.clipboard.writeText(code.textContent || '').then(() => {
								const btn = header.querySelector('.copy-btn');
								if (btn) {
									btn.innerHTML = `
										<svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
										</svg>
									`;
									pre.classList.add('copied');
									setTimeout(() => {
										btn.innerHTML = `
											<svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
											</svg>
										`;
										pre.classList.remove('copied');
									}, 2000);
								}
							});
						} else {
							pre.classList.toggle('collapsed');
						}
					});
				});

				const links = document.querySelectorAll('.prose a');
				links.forEach((link) => {
					const href = link.getAttribute('href');
					if (href && (href.startsWith('http://') || href.startsWith('https://'))) {
						link.setAttribute('target', '_blank');
						link.setAttribute('rel', 'noopener noreferrer');
					}
				});

				const images = document.querySelectorAll('.prose img');
				
				const seenImages = new Set();
				images.forEach((img) => {
					const htmlImg = img as HTMLElement;
					const src = img.getAttribute('src');
					
					if (src && !src.startsWith('data:') && htmlImg.offsetParent !== null) {
						if (seenImages.has(src)) {
							return;
						}
						seenImages.add(src);
						img.setAttribute('data-fancybox', 'gallery');
						img.setAttribute('data-src', src);
						img.setAttribute('data-caption', img.getAttribute('alt') || '');
						img.classList.add('cursor-pointer', 'hover:scale-105', 'transition-transform', 'duration-300');
					}
				});

				bindFancybox();
			});
		</script>
	</body>
</html>
