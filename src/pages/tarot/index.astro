  { name: '正义', num: 'XI', symbol: '⚖️', gradient: 'from-cyan-400 to-teal-500', lightGradient: 'from-cyan-600 to-teal-600', glow: 'rgba(34,211,238,0.4)', lightGlow: 'rgba(34,211,238,0.15)', upright: '公正、真相、因果、平衡', reversed: '不公、逃避责任、偏见', uprightAdvice: '公正待人，诚实面对自己', reversedAdvice: '正视偏颇，承担应负的责任' },
