---
import { getEntry } from 'astro:content';

interface Moment {
  content: string;
  date: string;
  images?: string[];
  link?: string;
}

interface WatchingItem {
  title: string;
  year: number;
  cover: string;
  comment: string;
  type: string;
  country?: string;
  ratings?: { source: string; score: number }[];
  links?: { source: string; url: string }[];
}

let recentMoments: Moment[] = [];
let watchingItems: WatchingItem[] = [];

try {
  const momentsData = await getEntry('post', 'moments');
  if (momentsData && momentsData.data.moments) {
    recentMoments = momentsData.data.moments
      .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime())
      .slice(0, 10)
      .map((m: any) => ({
        content: m.content,
        date: m.date,
        images: m.images || [],
        link: m.link || '',
      }));
  }
} catch (error) {
  console.log('Using empty moments data');
}

try {
  const watchingData = await getEntry('post', 'watching');
  if (watchingData && watchingData.data.watching) {
    watchingItems = watchingData.data.watching as WatchingItem[];
  }
} catch (error) {
  console.log('Using empty watching data');
}

const currentYear = new Date().getFullYear();
const endOfYear = new Date(currentYear, 11, 31, 23, 59, 59);
const now = new Date();
const daysLeft = Math.ceil((endOfYear.getTime() - now.getTime()) / (1000 * 60 * 60 * 24));
const yearProgress = Math.floor(((now.getTime() - new Date(currentYear, 0, 1).getTime()) / (endOfYear.getTime() - new Date(currentYear, 0, 1).getTime())) * 100);

const watchingJson = JSON.stringify(watchingItems.map(m => ({
  title: m.title,
  year: m.year,
  cover: m.cover,
  type: m.type,
  ratings: m.ratings
})));
---

{recentMoments.length > 0 && (
  <div id="moments-ticker" data-watching={watchingJson}>
    <div class="grid grid-cols-1 md:grid-cols-[1fr_200px] xl:grid-cols-[1fr_200px_200px_200px] gap-4">
      <a href="/moments" class="group block relative rounded-3xl shadow-sm hover:-translate-y-1 hover:shadow-xl transition-all duration-300 overflow-hidden ticker-gradient">
        <div class="absolute inset-0 pointer-events-none overflow-hidden">
          <svg class="ticker-signal absolute left-0 top-1/2 -translate-y-1/2 -translate-x-1/3 h-[200px] w-[200px]" viewBox="0 0 200 200" fill="none">
            <circle cx="100" cy="100" r="30" stroke="#fbbf24" stroke-width="0.8" opacity="0.15" class="ticker-ring-1" />
            <circle cx="100" cy="100" r="50" stroke="#fbbf24" stroke-width="0.6" opacity="0.10" class="ticker-ring-2" />
            <circle cx="100" cy="100" r="72" stroke="#fbbf24" stroke-width="0.5" opacity="0.07" class="ticker-ring-3" />
            <circle cx="100" cy="100" r="96" stroke="#fbbf24" stroke-width="0.4" opacity="0.04" class="ticker-ring-4" />
          </svg>
          <div class="ticker-shimmer"></div>
        </div>
        <div class="relative flex items-center h-12 px-4 gap-2.5 font-mono">
          <div class="relative flex-shrink-0">
            <img src="/img/avatar.webp" alt="" class="w-7 h-7 rounded-full object-cover border-2 border-amber-400/40" loading="lazy" decoding="async" />
            <div class="absolute -inset-0.5 rounded-full border border-amber-400/25 animate-[spin_8s_linear_infinite]" style="border-style: dashed;"></div>
          </div>
          <span class="text-amber-400 text-sm font-bold flex-shrink-0 tracking-tight">❯</span>
          <div class="flex items-center gap-1.5 px-2 py-0.5 bg-amber-400/15 rounded flex-shrink-0">
            <span class="w-1.5 h-1.5 rounded-full bg-amber-400 animate-pulse"></span>
            <span class="text-[10px] font-bold text-amber-400 whitespace-nowrap tracking-wider uppercase">live</span>
          </div>
          <div class="flex-1 overflow-hidden relative h-5">
            {recentMoments.map((moment, i) => (
              <span
                class="moments-item absolute inset-x-0 top-0 h-full flex items-center text-[13px] text-amber-400 transition-all duration-500"
                data-index={i}
              >
                <span class="truncate">{moment.content}</span>
              </span>
            ))}
          </div>
          <span class="ticker-cursor text-amber-400/70 text-sm font-light">█</span>
          <svg class="w-4 h-4 text-amber-400/40 flex-shrink-0 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </div>
      </a>

      <a href="/tarot" class="hidden md:flex items-center bg-card-light dark:bg-card-dark rounded-3xl shadow-sm hover:-translate-y-1 hover:shadow-xl transition-all duration-300 border border-transparent hover:border-border-light dark:hover:border-border-dark h-12 px-3 gap-2.5 group/status">
        <div class="w-7 h-7 rounded-xl bg-primary-light/10 dark:bg-primary-dark/10 flex items-center justify-center flex-shrink-0 text-sm">
          🔮
        </div>
        <div class="flex flex-col min-w-0">
          <div class="flex items-center gap-1.5">
            <span class="text-[11px] text-text-light/70 dark:text-text-dark/70 font-medium truncate">趣味塔罗</span>
            <span class="w-1.5 h-1.5 rounded-full bg-amber-400 animate-pulse flex-shrink-0"></span>
          </div>
          <span class="text-[10px] text-text-light/40 dark:text-text-dark/40 truncate">点击抽牌</span>
        </div>
        <svg class="w-3 h-3 text-text-light/30 dark:text-text-dark/30 flex-shrink-0 transition-transform duration-300 group-hover/status:translate-x-0.5 ml-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      </a>

      <a href="/progress" class="hidden xl:flex items-center bg-card-light dark:bg-card-dark rounded-3xl shadow-sm hover:-translate-y-1 hover:shadow-xl transition-all duration-300 border border-transparent hover:border-border-light dark:hover:border-border-dark h-12 px-3 gap-2.5 group/progress">
        <div class="flex-shrink-0 relative w-7 h-7">
          <svg class="w-7 h-7 -rotate-90" viewBox="0 0 36 36">
            <circle cx="18" cy="18" r="15.5" fill="none" stroke="currentColor" stroke-width="3" class="text-hover-light dark:text-hover-dark"></circle>
            <circle cx="18" cy="18" r="15.5" fill="none" stroke="currentColor" stroke-width="3" stroke-dasharray={`${yearProgress * 0.974} 97.4`} stroke-linecap="round" class="text-primary-light dark:text-primary-dark transition-all duration-1000"></circle>
          </svg>
          <div class="absolute inset-0 flex items-center justify-center">
            <span class="text-[8px] font-bold text-primary-light dark:text-primary-dark">{yearProgress}%</span>
          </div>
        </div>
        <div class="flex flex-col min-w-0">
          <span class="text-[10px] text-text-light/40 dark:text-text-dark/40 leading-tight">{currentYear} 进度</span>
          <span class="text-[11px] text-text-light/70 dark:text-text-dark/70 font-medium leading-tight">剩余 <span class="text-primary-light dark:text-primary-dark font-bold">{daysLeft}</span> 天</span>
        </div>
        <svg class="w-3 h-3 text-text-light/30 dark:text-text-dark/30 flex-shrink-0 transition-transform duration-300 group-hover/progress:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      </a>

      <a id="movie-recommend-link" href="/time-machine" class="hidden xl:flex items-center bg-card-light dark:bg-card-dark rounded-3xl shadow-sm hover:-translate-y-1 hover:shadow-xl transition-all duration-300 border border-transparent hover:border-border-light dark:hover:border-border-dark h-12 px-3 gap-2 group/movie">
        <div class="w-7 h-7 rounded-xl overflow-hidden flex-shrink-0 bg-hover-light dark:bg-hover-dark" id="movie-cover-wrapper">
          <img id="movie-cover" src="" alt="" class="w-full h-full object-cover" loading="lazy" decoding="async" />
        </div>
        <div class="flex-1 min-w-0">
          <span id="movie-recommend-text" class="text-[11px] text-text-light/70 dark:text-text-dark/70 truncate block">推荐中...</span>
          <span id="movie-recommend-meta" class="text-[10px] text-text-light/40 dark:text-text-dark/40 truncate block"></span>
        </div>
        <svg class="w-3 h-3 text-text-light/30 dark:text-text-dark/30 flex-shrink-0 transition-transform duration-300 group-hover/movie:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      </a>
    </div>
  </div>
)}

<script>
  function initMomentsTicker() {
    const container = document.getElementById('moments-ticker');
    if (!container) return;

    const items = container.querySelectorAll('.moments-item');
    if (items.length === 0) return;

    items.forEach((item, i) => {
      const el = item as HTMLElement;
      if (i === 0) {
        el.style.opacity = '1';
        el.style.transform = 'translateY(0)';
      } else {
        el.style.opacity = '0';
        el.style.transform = 'translateY(100%)';
      }
    });

    let currentIndex = 0;

    const timer = setInterval(() => {
      const prevIndex = currentIndex;
      currentIndex = (currentIndex + 1) % items.length;

      const prev = items[prevIndex] as HTMLElement;
      const next = items[currentIndex] as HTMLElement;

      if (prev) {
        prev.style.opacity = '0';
        prev.style.transform = 'translateY(-100%)';
      }
      if (next) {
        next.style.opacity = '1';
        next.style.transform = 'translateY(0)';
      }

      setTimeout(() => {
        if (prev) {
          prev.style.transition = 'none';
          prev.style.transform = 'translateY(100%)';
          void prev.offsetHeight;
          prev.style.transition = 'all 0.5s cubic-bezier(0.4, 0, 0.2, 1)';
        }
      }, 500);
    }, 3500);

    (container as any).__momentsTimer = timer;

    const watchingRaw = container.getAttribute('data-watching');
    if (watchingRaw) {
      try {
        const watchingItems = JSON.parse(watchingRaw);
        if (watchingItems && watchingItems.length > 0) {
          const idx = Math.floor(Math.random() * watchingItems.length);
          const movie = watchingItems[idx];
          const movieEl = document.getElementById('movie-recommend-text');
          const movieMetaEl = document.getElementById('movie-recommend-meta');
          const movieCoverEl = document.getElementById('movie-cover') as HTMLImageElement;
          const movieLink = document.getElementById('movie-recommend-link') as HTMLAnchorElement;
          if (movieEl && movie) {
            movieEl.textContent = movie.title;
          }
          if (movieMetaEl && movie) {
            const parts: string[] = [];
            if (movie.type) parts.push(movie.type);
            if (movie.year) parts.push(String(movie.year));
            if (movie.ratings && movie.ratings.length > 0) parts.push(movie.ratings[0].score.toFixed(1));
            movieMetaEl.textContent = parts.join(' · ');
          }
          if (movieCoverEl && movie && movie.cover) {
            movieCoverEl.src = movie.cover;
            movieCoverEl.alt = movie.title;
          }
          if (movieLink) {
            movieLink.href = `/time-machine?idx=${idx}`;
          }
        }
      } catch (e) {
        // ignore
      }
    }
  }

  function cleanupMomentsTicker() {
    const container = document.getElementById('moments-ticker');
    if (container && (container as any).__momentsTimer) {
      clearInterval((container as any).__momentsTimer);
      (container as any).__momentsTimer = null;
    }
  }

  document.addEventListener('astro:page-load', () => {
    cleanupMomentsTicker();
    initMomentsTicker();
  });

  document.addEventListener('astro:after-swap', () => {
    cleanupMomentsTicker();
    initMomentsTicker();
  });

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMomentsTicker);
  } else {
    initMomentsTicker();
  }
</script>

<style is:global>
  .ticker-gradient {
    background: #0c1222;
  }

  .dark .ticker-gradient {
    background: #0a0f1a;
  }

  .ticker-shimmer {
    position: absolute;
    top: 0;
    left: -100%;
    width: 60%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(251, 191, 36, 0.04) 40%,
      rgba(251, 191, 36, 0.10) 50%,
      rgba(251, 191, 36, 0.04) 60%,
      transparent 100%
    );
    animation: ticker-shimmer 6s ease-in-out infinite;
  }

  .dark .ticker-shimmer {
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(251, 191, 36, 0.04) 40%,
      rgba(251, 191, 36, 0.10) 50%,
      rgba(251, 191, 36, 0.04) 60%,
      transparent 100%
    );
  }

  @keyframes ticker-shimmer {
    0%, 20% { left: -100%; }
    60%, 100% { left: 150%; }
  }

  .ticker-cursor {
    animation: ticker-blink 1s step-end infinite;
  }

  @keyframes ticker-blink {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0; }
  }

  .ticker-ring-1 {
    animation: ticker-ring-pulse 3s ease-out infinite;
  }
  .ticker-ring-2 {
    animation: ticker-ring-pulse 3s ease-out 0.6s infinite;
  }
  .ticker-ring-3 {
    animation: ticker-ring-pulse 3s ease-out 1.2s infinite;
  }
  .ticker-ring-4 {
    animation: ticker-ring-pulse 3s ease-out 1.8s infinite;
  }

  @keyframes ticker-ring-pulse {
    0% { opacity: 0; transform: scale(0.7); transform-origin: center; }
    30% { opacity: 0.2; }
    100% { opacity: 0; transform: scale(1.1); transform-origin: center; }
  }
</style>
