---
interface Props {
	elId?: string;
}

const { elId: customElId } = Astro.props;
const envId = 'https://twikoo.1k.ink';

const pageKey = (() => {
	try {
		return Astro.url.pathname || '/';
	} catch {
		return '/';
	}
})();

const elId = customElId ?? `tcomment-${pageKey.replace(/[^a-zA-Z0-9]+/g, '-').replace(/^-+|-+$/g, '') || 'root'}`;
---
<div id={elId} class="twikoo" data-twikoo-env-id={envId}></div>

<script>
  declare global {
    interface Window {
      twikoo?: { init: (options: { envId: string; el: string; lang: string; path: string }) => void };
      __twikooLoader?: { promise: Promise<void> | null };
      __twikooAstro?: { listeners: boolean };
    }
  }

  const TWIKOO_SRC = 'https://registry.npmmirror.com/twikoo/1.7.1/files/dist/twikoo.nocss.js';

  function getTwikooMounts(): Element[] {
    return Array.from(document.querySelectorAll('.twikoo[data-twikoo-env-id]'));
  }

  function waitForTwikooGlobal(timeoutMs = 3000): Promise<void> {
    const start = performance.now();
    return new Promise((resolve, reject) => {
      const tick = () => {
        if (window.twikoo && typeof window.twikoo.init === 'function') return resolve();
        if (performance.now() - start > timeoutMs) return reject(new Error('twikoo global timeout'));
        requestAnimationFrame(tick);
      };
      tick();
    });
  }

  function waitForTwikooCssLink(timeoutMs = 3000): Promise<void> {
    const link = document.head.querySelector<HTMLLinkElement>('link[rel="stylesheet"][href*="twikoo-base.css"]');
    if (!link) return Promise.resolve();
    if (link.sheet) return Promise.resolve();

    return new Promise((resolve) => {
      const timer = setTimeout(resolve, timeoutMs);
      const done = () => {
        clearTimeout(timer);
        resolve();
      };
      link.addEventListener('load', done, { once: true });
      link.addEventListener('error', done, { once: true });
    });
  }

  async function ensureTwikooLoaded(): Promise<void> {
    if (window.twikoo && typeof window.twikoo.init === 'function') return;
    window.__twikooLoader = window.__twikooLoader || { promise: null };
    if (window.__twikooLoader!.promise) {
      await window.__twikooLoader!.promise;
      return;
    }

    window.__twikooLoader!.promise = new Promise<void>((resolve, reject) => {
      const existing = document.getElementById('twikoo-script');
      if (existing) {
        existing.setAttribute('data-astro-transition-persist', '');
        if (window.twikoo && typeof window.twikoo.init === 'function') return resolve();

        existing.addEventListener('load', () => resolve(), { once: true });
        existing.addEventListener('error', () => reject(new Error('twikoo script load error')), { once: true });
        return;
      }

      const script = document.createElement('script');
      script.id = 'twikoo-script';
      script.src = TWIKOO_SRC;
      script.async = true;
      script.setAttribute('data-astro-transition-persist', '');
      script.onload = () => resolve();
      script.onerror = (e) => {
        window.__twikooLoader!.promise = null;
        reject(e);
      };
      document.head.appendChild(script);
    });

    await window.__twikooLoader!.promise;
    await waitForTwikooGlobal();
  }

  function initTwikooForMount(mountEl: Element) {
    if (!window.twikoo || typeof window.twikoo.init !== 'function') return;
    if (!(mountEl instanceof Element)) return;

    const envId = mountEl.getAttribute('data-twikoo-env-id');
    if (!envId) return;
    if (!mountEl.id) return;

    mountEl.innerHTML = '';

    window.twikoo.init({
      envId,
      el: `#${mountEl.id}`,
      lang: 'zh-CN',
      path: window.location.pathname,
    });
  }

  function boot() {
    const mounts = getTwikooMounts();
    if (!mounts.length) return;

    const initializedMounts = new Set<string>();
    document.querySelectorAll('.twikoo[data-twikoo-env-id]').forEach(el => {
      if (el.children.length > 0) {
        initializedMounts.add(el.id);
      }
    });

    const init = () => {
      waitForTwikooCssLink()
        .then(() => ensureTwikooLoaded())
        .then(() => {
          requestAnimationFrame(() =>
            requestAnimationFrame(() => {
              for (const m of mounts) {
                if (!initializedMounts.has(m.id)) {
                  initTwikooForMount(m);
                }
              }
            }),
          );
        })
        .catch(() => {
          // ignore
        });
    };

    if ('requestIdleCallback' in window) {
      window.requestIdleCallback(() => init(), { timeout: 2000 });
    } else {
      setTimeout(init, 100);
    }
  }

  if (!window.__twikooAstro) {
    window.__twikooAstro = { listeners: true };
    document.addEventListener('astro:page-load', boot);
    document.addEventListener('astro:after-swap', boot);
  }
</script>
