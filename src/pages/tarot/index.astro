  { name: '死神', num: 'XIII', symbol: '🦋', gradient: 'from-gray-500 to-slate-600', lightGradient: 'from-gray-600 to-slate-700', glow: 'rgba(100,116,139,0.4)', lightGlow: 'rgba(100,116,139,0.15)', upright: '结束、转变、重生、放下过去', reversed: '抗拒改变、勉强维持、停滞不前', uprightAdvice: '主动放下旧的，才能迎接新的', reversedAdvice: '不要勉强维持已结束的状态，果断松手' },
  { name: '节制', num: 'XIV', symbol: '🏺', gradient: 'from-teal-400 to-cyan-500', lightGradient: 'from-teal-600 to-cyan-600', glow: 'rgba(45,212,191,0.4)', lightGlow: 'rgba(45,212,191,0.15)', upright: '平衡、节制、耐心、调和', reversed: '失衡、过度、缺乏耐心', uprightAdvice: '保持中庸，凡事适度', reversedAdvice: '找回平衡，避免走极端' },
  { name: '恶魔', num: 'XV', symbol: '🔗', gradient: 'from-red-500 to-purple-700', lightGradient: 'from-red-700 to-purple-800', glow: 'rgba(168,85,247,0.4)', lightGlow: 'rgba(168,85,247,0.15)', upright: '束缚、诱惑、欲望、物质执念', reversed: '释放、觉醒、打破束缚', uprightAdvice: '审视执念，不要被欲望控制', reversedAdvice: '挣脱束缚的时机已到，勇敢解放自己' },
  { name: '塔', num: 'XVI', symbol: '⚡', gradient: 'from-red-400 to-orange-600', lightGradient: 'from-red-600 to-orange-700', glow: 'rgba(248,113,113,0.4)', lightGlow: 'rgba(248,113,113,0.15)', upright: '突变、崩塌、真相揭露', reversed: '余震未消、隐患尚在、缓慢重建', uprightAdvice: '废墟之上，才能重建更好的生活', reversedAdvice: '最猛烈的风暴已过，耐下心来一件件修补' },
  { name: '星星', num: 'XVII', symbol: '⭐', gradient: 'from-yellow-300 to-amber-400', lightGradient: 'from-yellow-500 to-amber-500', glow: 'rgba(252,211,77,0.4)', lightGlow: 'rgba(252,211,77,0.15)', upright: '希望、灵感、宁静、祝福', reversed: '失去信心、迷失方向', uprightAdvice: '相信希望，星光终会指引你', reversedAdvice: '重新连接内心的光，希望从未远离' },
  { name: '月亮', num: 'XVIII', symbol: '🌕', gradient: 'from-indigo-300 to-purple-500', lightGradient: 'from-indigo-500 to-purple-600', glow: 'rgba(165,180,252,0.4)', lightGlow: 'rgba(165,180,252,0.15)', upright: '幻象、潜意识、直觉、不安', reversed: '走出迷雾、真相显现', uprightAdvice: '面对内心的恐惧，真相就在迷雾后', reversedAdvice: '迷雾正在散去，准备好迎接真相' },
  { name: '太阳', num: 'XIX', symbol: '☀️', gradient: 'from-yellow-400 to-orange-400', lightGradient: 'from-yellow-600 to-orange-500', glow: 'rgba(250,204,21,0.5)', lightGlow: 'rgba(250,204,21,0.2)', upright: '成功、快乐、活力、光明', reversed: '短暂挫折、过度乐观', uprightAdvice: '尽情绽放，今天属于你', reversedAdvice: '阳光暂时被遮挡，但温暖仍在' },
  { name: '审判', num: 'XX', symbol: '📯', gradient: 'from-rose-400 to-pink-500', lightGradient: 'from-rose-600 to-pink-600', glow: 'rgba(251,113,133,0.4)', lightGlow: 'rgba(251,113,133,0.15)', upright: '觉醒、重生、审视、召唤', reversed: '自我怀疑、拒绝成长', uprightAdvice: '审视过去，迎接内心的召唤', reversedAdvice: '停止自我否定，允许自己成长' },
  { name: '世界', num: 'XXI', symbol: '🌍', gradient: 'from-emerald-400 to-violet-500', lightGradient: 'from-emerald-600 to-violet-600', glow: 'rgba(52,211,153,0.4)', lightGlow: 'rgba(52,211,153,0.15)', upright: '圆满、完成、成就、和谐', reversed: '美中不足、延迟圆满、最后一步', uprightAdvice: '一切圆满，享受此刻的成就', reversedAdvice: '只差最后的临门一脚，耐心补齐最后一块拼图' },
];

const today = new Date();
const dateSeed = today.getFullYear() * 10000 + (today.getMonth() + 1) * 100 + today.getDate();

function seededRandom(seed: number) {
  let s = seed;
  return () => {
    s = (s * 9301 + 49297) % 233280;
    return s / 233280;
  };
}

const rng = seededRandom(dateSeed);
const cardIdx = Math.floor(rng() * tarotCards.length);
const isUpright = rng() > 0.5;
const card = tarotCards[cardIdx];

const dateStr = `${today.getFullYear()}.${String(today.getMonth() + 1).padStart(2, '0')}.${String(today.getDate()).padStart(2, '0')}`;
const weekDays = ['日', '一', '二', '三', '四', '五', '六'];
const weekDay = weekDays[today.getDay()];
---

<MainLayout title="趣味塔罗" description="抽一张塔罗牌，探索今日指引">
  <section class="tarot-page min-h-[80vh] flex items-center justify-center px-4 sm:px-6 pt-28 pb-16">
    <div id="tarot-data" class="hidden"
      data-cards={JSON.stringify(tarotCards.map(c => ({ name: c.name, num: c.num, symbol: c.symbol, gradient: c.gradient, lightGradient: c.lightGradient, glow: c.glow, lightGlow: c.lightGlow, upright: c.upright, reversed: c.reversed, uprightAdvice: c.uprightAdvice, reversedAdvice: c.reversedAdvice })))}
    ></div>
    <div class="w-full max-w-md relative z-10">

      <div id="tarot-scene" class="tarot-scene">
        <div id="fortune-card" class="tarot-card-inner">

          <div class="tarot-face tarot-face-front">
            <div class="flex flex-col items-center justify-center h-full gap-6">
              <div class="relative">
                <div class="tarot-back-pattern w-28 h-40 sm:w-32 sm:h-44 rounded-xl flex items-center justify-center border-2 border-amber-400/30 dark:border-amber-400/20 relative overflow-hidden">
                  <div class="absolute inset-2 border border-amber-400/20 dark:border-amber-400/15 rounded-lg"></div>
                  <div class="absolute inset-4 border border-amber-400/10 dark:border-amber-400/10 rounded-md"></div>
                  <div class="relative z-10 text-center">
                    <div class="text-amber-500/40 dark:text-amber-400/30 text-3xl mb-1">✦</div>
                    <div class="text-amber-600/30 dark:text-amber-400/20 text-[8px] tracking-[0.3em] font-mono uppercase">Tarot</div>
                  </div>
                </div>
                <div class="absolute -inset-4 rounded-2xl border border-amber-400/10 dark:border-amber-400/5 animate-ping" style="animation-duration: 3s;"></div>
              </div>
              <div class="text-center">
                <p class="text-black/30 dark:text-white/40 text-xs font-mono tracking-widest mb-1.5">{dateStr} · 周{weekDay}</p>
                <p class="text-black/50 dark:text-white/70 text-sm">点击抽一张塔罗牌</p>
              </div>
            </div>
          </div>

          <div class="tarot-face tarot-face-back">
            <div class="tarot-glow" style={`--glow-color: ${card.glow}; --glow-color-light: ${card.lightGlow}`}></div>

            <div class="relative z-10 p-8 sm:p-10">
              <div class="flex items-center justify-between mb-8">
                <span class="text-black/25 dark:text-white/30 text-xs font-mono tracking-wider">{dateStr}</span>
                <span class="text-black/25 dark:text-white/30 text-xs">周{weekDay}</span>
              </div>

              <div class="text-center mb-8">
                <div class={`tarot-card-symbol text-5xl mb-3 ${!isUpright ? 'rotate-180' : ''}`}>{card.symbol}</div>
                <div class={`tarot-card-name inline-block text-4xl sm:text-5xl font-black bg-gradient-to-r ${card.lightGradient} dark:${card.gradient} bg-clip-text text-transparent mb-2 leading-tight`}>
                  {card.name}
                </div>
                <div class="tarot-card-num text-black/20 dark:text-white/20 text-xs font-mono tracking-[0.4em]">{card.num}</div>
              </div>

              <div class="mb-6">
                <div class={`tarot-position-tag inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-mono tracking-wider mb-4 ${isUpright ? 'bg-emerald-500/[0.08] dark:bg-emerald-400/[0.08] text-emerald-600 dark:text-emerald-400 border border-emerald-500/[0.1] dark:border-emerald-400/[0.1]' : 'bg-rose-500/[0.08] dark:bg-rose-400/[0.08] text-rose-600 dark:text-rose-400 border border-rose-500/[0.1] dark:border-rose-400/[0.1]'}`}>
                  <span class={`w-1.5 h-1.5 rounded-full ${isUpright ? 'bg-emerald-500 dark:bg-emerald-400' : 'bg-rose-500 dark:bg-rose-400'}`}></span>
                  <span class="tarot-position-label">{isUpright ? '正位' : '逆位'}</span>
                </div>
                <p class="tarot-card-meaning text-black/60 dark:text-white/70 text-base leading-relaxed">{isUpright ? card.upright : card.reversed}</p>
              </div>

              <div class="text-center px-4 py-4 rounded-xl bg-amber-500/[0.06] dark:bg-amber-400/[0.06] border border-amber-500/[0.08] dark:border-amber-400/[0.08]">
                <span class="text-amber-600 dark:text-amber-400 text-[10px] font-mono tracking-[0.2em]">指引</span>
                <p class="tarot-card-advice text-black/60 dark:text-white/70 text-base font-medium mt-2 leading-relaxed">{isUpright ? card.uprightAdvice : card.reversedAdvice}</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div id="tarot-actions" class="mt-8 flex items-center justify-center gap-3 opacity-0 transition-opacity duration-500">
        <button id="tarot-redraw" class="group flex items-center gap-2 px-5 py-2.5 rounded-full bg-black/[0.04] dark:bg-white/5 border border-black/[0.08] dark:border-white/10 hover:border-amber-400/30 dark:hover:border-amber-400/20 hover:bg-amber-50/50 dark:hover:bg-amber-400/5 transition-all duration-300 text-sm text-black/50 dark:text-white/60 hover:text-amber-700 dark:hover:text-amber-300">
          <svg class="w-4 h-4 transition-transform duration-500 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
          </svg>
          再抽一张
        </button>
      </div>

      <div id="tarot-particles" class="tarot-particles"></div>
    </div>
  </section>
</MainLayout>

<script>
  function initTarot() {
    const scene = document.getElementById('tarot-scene');
    const cardEl = document.getElementById('fortune-card');
    const actions = document.getElementById('tarot-actions');
    const particles = document.getElementById('tarot-particles');
    const dataEl = document.getElementById('tarot-data') as HTMLElement;
    let flipped = false;

    if (!cardEl || !scene || !dataEl) return;

    const cards = JSON.parse(dataEl.dataset.cards || '[]');

    scene.addEventListener('click', () => {
      if (flipped) return;
      flipped = true;
      cardEl.classList.add('flipped');

      setTimeout(() => {
        if (actions) actions.style.opacity = '1';
      }, 600);
    });

    function randomPick(arr: any[]): any {
      return arr[Math.floor(Math.random() * arr.length)];
    }

    function generateTarot() {
      const card = randomPick(cards);
      const isUpright = Math.random() > 0.5;
      return { card, isUpright };
    }

    function updateCard(data: ReturnType<typeof generateTarot>) {
      const isDark = document.documentElement.classList.contains('dark');
      const { card, isUpright } = data;

      const glow = document.querySelector('.tarot-glow') as HTMLElement;
      if (glow) {
        glow.style.setProperty('--glow-color', card.glow);
        glow.style.setProperty('--glow-color-light', card.lightGlow);
      }

      const symbolEl = document.querySelector('.tarot-card-symbol') as HTMLElement;
      if (symbolEl) {
        symbolEl.textContent = card.symbol;
        symbolEl.classList.toggle('rotate-180', !isUpright);
      }

      const nameEl = document.querySelector('.tarot-card-name') as HTMLElement;
      if (nameEl) {
        nameEl.textContent = card.name;
        nameEl.className = `tarot-card-name inline-block text-4xl sm:text-5xl font-black bg-gradient-to-r ${isDark ? card.gradient : card.lightGradient} bg-clip-text text-transparent mb-2 leading-tight`;
      }

      const numEl = document.querySelector('.tarot-card-num') as HTMLElement;
      if (numEl) numEl.textContent = card.num;

      const positionTag = document.querySelector('.tarot-position-tag') as HTMLElement;
      if (positionTag) {
        if (isUpright) {
          positionTag.className = 'tarot-position-tag inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-mono tracking-wider mb-4 bg-emerald-500/[0.08] dark:bg-emerald-400/[0.08] text-emerald-600 dark:text-emerald-400 border border-emerald-500/[0.1] dark:border-emerald-400/[0.1]';
        } else {
          positionTag.className = 'tarot-position-tag inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-mono tracking-wider mb-4 bg-rose-500/[0.08] dark:bg-rose-400/[0.08] text-rose-600 dark:text-rose-400 border border-rose-500/[0.1] dark:border-rose-400/[0.1]';
        }
        const dot = positionTag.querySelector('.tarot-position-dot') as HTMLElement;
        if (dot) {
          dot.className = `tarot-position-dot w-1.5 h-1.5 rounded-full ${isUpright ? 'bg-emerald-500 dark:bg-emerald-400' : 'bg-rose-500 dark:bg-rose-400'}`;
        }
        const label = positionTag.querySelector('.tarot-position-label') as HTMLElement;
        if (label) label.textContent = isUpright ? '正位' : '逆位';
      }

      const meaningEl = document.querySelector('.tarot-card-meaning') as HTMLElement;
      if (meaningEl) meaningEl.textContent = isUpright ? card.upright : card.reversed;

      const adviceEl = document.querySelector('.tarot-card-advice') as HTMLElement;
      if (adviceEl) adviceEl.textContent = isUpright ? card.uprightAdvice : card.reversedAdvice;
    }

    const redrawBtn = document.getElementById('tarot-redraw');
    if (redrawBtn) {
      redrawBtn.addEventListener('click', () => {
        if (!cardEl) return;

        cardEl.classList.remove('flipped');
        flipped = false;

        setTimeout(() => {
          const data = generateTarot();
          updateCard(data);

          setTimeout(() => {
            flipped = true;
            cardEl.classList.add('flipped');
          }, 400);
        }, 400);
      });
    }

    if (particles) {
      for (let i = 0; i < 30; i++) {
        const dot = document.createElement('div');
        dot.className = 'tarot-dot';
        dot.style.left = Math.random() * 100 + '%';
        dot.style.top = Math.random() * 100 + '%';
        dot.style.animationDelay = Math.random() * 6 + 's';
        dot.style.animationDuration = (4 + Math.random() * 4) + 's';
        const size = 1 + Math.random() * 2;
        dot.style.width = size + 'px';
        dot.style.height = size + 'px';
        particles.appendChild(dot);
      }
    }
  }

  document.addEventListener('astro:page-load', initTarot);
</script>

<style is:global>
  .tarot-page {
    position: relative;
  }

  .tarot-page::before {
    content: '';
    position: fixed;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 50% at 50% -20%, rgba(120, 80, 255, 0.04), transparent),
      radial-gradient(ellipse 60% 40% at 80% 100%, rgba(245, 158, 11, 0.03), transparent),
      radial-gradient(ellipse 60% 40% at 20% 80%, rgba(59, 130, 246, 0.03), transparent);
    pointer-events: none;
    z-index: 0;
  }

